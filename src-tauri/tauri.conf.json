{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoundCloud Desktop",
  "version": "0.1.0",
  "identifier": "com.enyouki.soundcloud",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SoundCloud",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/audio/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGRkNEMDk4OEVGMDU1N0QKUldSOVZmQ09tTkQ4djltbnpoWUNnVEliN3lweWljUExXZnFnQjJwT1lLaEMxZXhVZHFha1lDUTAK",
      "endpoints": [
        "https://github.com/inkitori/soundcloud-desktop/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
